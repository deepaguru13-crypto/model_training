ect numerical features\n","numerical_features = df_cleaned.select_dtypes(include=['float64', 'int64']).columns\n","\n","# Create box plots for all numerical features\n","for feature in numerical_features:\n","    plt.figure(figsize=(10, 6))\n","    sns.boxplot(x=df_cleaned[feature])\n","    plt.title(f\"Box plot for {feature}\")\n","    plt.show()\n","\n","    # Save each plot as PNG in the specified directory\n","    plot_filename = f\"/content/drive/MyDrive/CapstoneCYBER/boxplot_{feature}.png\"\n","    plt.savefig(plot_filename, dpi=300)\n","    print(f\"Box plot for {feature} saved as {plot_filename}\")"],"metadata":{"id":"X7GfnSN3irTx"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# Function to detect outliers using IQR\n","def detect_outliers_iqr(df, feature):\n","    Q1 = df[feature].quantile(0.25)\n","    Q3 = df[feature].quantile(0.75)\n","    IQR = Q3 - Q1\n","    lower_bound = Q1 - 1.5 * IQR\n","    upper_bound = Q3 + 1.5 * IQR\n","    return df[(df[feature] < lower_bound) | (df[feature] > upper_bound)]\n","\n","# Loop through each numerical feature and detect outliers using IQR\n","numerical_features = df_cleaned.select_dtypes(include=['float64', 'int64']).columns\n","\n","# Print outliers for each feature\n","for feature in numerical_features:\n","    outliers = detect_outliers_iqr(df_cleaned, feature)\n","    print(f\"Number of outliers in '{feature}': {len(outliers)}\")"],"metadata":{"id":"tFRTmJYXi0L4"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# Group by 'label' and calculate summary statistics for each feature\n","grouped_stats = df_cleaned.groupby('label').describe().transpose()\n","\n","# Display the grouped statistics\n","print(grouped_stats)"],"metadata":{"id":"bqafpKeQi8ff"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["import seaborn as sns\n","import matplotlib.pyplot as plt\n","\n","# Select the features to plot\n","features_to_plot = ['URLLength', 'DomainLength', 'NumSpe